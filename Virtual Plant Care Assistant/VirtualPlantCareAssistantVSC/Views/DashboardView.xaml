<Page x:Class="VirtualPlantCareAssistantVSC.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="DashboardView" Loaded="Page_Loaded">

    <Grid Background="#F4F7F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FFFFFF" materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <materialDesign:PackIcon Kind="Leaf" Foreground="#2E7D32" Width="30" Height="30" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Plant Care" Foreground="#1B5E20" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2E7D32" HorizontalContentAlignment="Left" Height="50" Margin="10,5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dashboard" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="CareScheduleButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Care Schedule" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="RemindersButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BellRingOutline" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Reminders" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="CareHistoryButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="History" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Care History" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Right Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Banner -->
            <Border Grid.Row="0" Height="140" materialDesign:ElevationAssist.Elevation="Dp4">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/Images/dashboard_header.png" Stretch="UniformToFill" Opacity="0.9"/>
                </Border.Background>
                <Grid Background="#44FFFFFF">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Virtual Plant Dashboard" Foreground="#1B5E20" FontSize="26"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="25,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="White" BlurRadius="6" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock x:Name="WelcomeTextBlock" Text="Welcome!" Foreground="#1B5E20" FontSize="17"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="LOGOUT" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="LogoutButton_Click" Foreground="#2E7D32" BorderBrush="#2E7D32" Background="#DDFFFFFF"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- My Plants title + Search + Add button -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="My Plants" FontSize="22" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                    
                    <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="40,0" Height="40" 
                            materialDesign:ElevationAssist.Elevation="Dp1" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#666" Margin="15,0,10,0" VerticalAlignment="Center" Width="20" Height="20"/>
                            <TextBox Grid.Column="1" x:Name="SearchTextBox" 
                                     materialDesign:HintAssist.Hint="Search your plants..." 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     BorderThickness="0" VerticalAlignment="Center" 
                                     Margin="0,0,15,0" Background="Transparent"
                                     FontSize="14" TextChanged="SearchTextBox_TextChanged"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Content="+ Add Plant" Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4CAF50" BorderBrush="#4CAF50"
                            Foreground="White" Click="AddPlantButton_Click" Height="40" Padding="20,0"/>
                </Grid>

                <!-- Plant Cards -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PlantsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" Width="290" Margin="0,0,18,18"
                                        materialDesign:ElevationAssist.Elevation="Dp3" ClipToBounds="True">
                                    <StackPanel>

                                        <!-- Clickable image + name area -->
                                        <Button Padding="0" BorderThickness="0" Background="Transparent"
                                                Tag="{Binding}" Click="PlantCard_Click" Cursor="Hand" Height="170">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Height="170" ClipToBounds="True">
                                                        <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                                        <Border Background="#88000000" VerticalAlignment="Bottom" Padding="12,8">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="Bold" Foreground="White"/>
                                                                <TextBlock Text="{Binding Species}" FontSize="12" Foreground="#CCCCCC"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Status badges -->
                                        <StackPanel Orientation="Horizontal" Margin="12,8,12,4">
                                            <Border CornerRadius="10" Padding="8,3" Margin="0,0,6,0"
                                                    Background="{Binding WateringStatusColor}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="WaterDrop" Width="11" Height="11"
                                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding WateringStatus}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border CornerRadius="10" Padding="8,3"
                                                    Background="{Binding FertilizationStatusColor}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Sprout" Width="11" Height="11"
                                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding FertilizationStatus}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Care info rows -->
                                        <StackPanel Margin="12,2,12,10">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <materialDesign:PackIcon Kind="WaterDrop" Foreground="#2196F3" Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding WateringFrequencyDays, StringFormat='Every {0}d'}" Foreground="#555" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="  •  " Foreground="#AAA" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding NextWateringText}" Foreground="#777" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <materialDesign:PackIcon Kind="Sprout" Foreground="#8BC34A" Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding FertilizationFrequencyDays, StringFormat='Every {0}d'}" Foreground="#555" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="  •  " Foreground="#AAA" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding NextFertilizationText}" Foreground="#777" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Content="WATER" Style="{StaticResource MaterialDesignRaisedButton}"
                                                        Background="#2196F3" BorderBrush="#2196F3" Foreground="White"
                                                        Grid.Column="0" Margin="0,0,4,0" Padding="4,0" FontSize="11"
                                                        Tag="{Binding PlantId}" Click="WaterButton_Click"/>
                                                <Button Content="FERTILIZE" Style="{StaticResource MaterialDesignRaisedButton}"
                                                        Background="#8BC34A" BorderBrush="#8BC34A" Foreground="White"
                                                        Grid.Column="1" Margin="0,0,4,0" Padding="4,0" FontSize="11"
                                                        Tag="{Binding PlantId}" Click="FertilizeButton_Click"/>
                                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                        Grid.Column="2" ToolTip="Delete Plant"
                                                        Tag="{Binding PlantId}" Click="DeleteButton_Click">
                                                    <materialDesign:PackIcon Kind="Delete" Foreground="#F44336"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
