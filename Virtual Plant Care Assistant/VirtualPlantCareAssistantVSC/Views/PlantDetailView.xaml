<Page x:Class="VirtualPlantCareAssistantVSC.Views.PlantDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="PlantDetailView" Loaded="Page_Loaded">

    <Grid Background="#F4F7F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="260"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero Image Banner -->
        <Grid Grid.Row="0">
            <Image x:Name="HeroImage" Stretch="UniformToFill"/>
            <Border Background="#88000000"/>
            <!-- Back Button -->
            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="16,16,0,0" Click="BackButton_Click" ToolTip="Back to Dashboard">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="White"/>
            </Button>
            <!-- Plant Name overlay -->
            <StackPanel VerticalAlignment="Bottom" Margin="30,0,30,24">
                <TextBlock x:Name="PlantNameText" Text="" FontSize="36" FontWeight="Bold" Foreground="White">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="PlantSpeciesText" Text="" FontSize="18" Foreground="#DDDDDD"/>
            </StackPanel>
        </Grid>

        <!-- Detail Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,24,30,30">

                <!-- Care Status Cards Row -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Watering Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12"
                            materialDesign:ElevationAssist.Elevation="Dp2" Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="WaterDrop" Foreground="#2196F3" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Watering" FontSize="18" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="WateringStatusBadge" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock x:Name="WateringStatusText" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Frequency:" Foreground="#888" FontSize="13" Margin="0,0,10,6"/>
                                <TextBlock x:Name="WaterFreqText" Grid.Row="0" Grid.Column="1" FontSize="13" Foreground="#333" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Last watered:" Foreground="#888" FontSize="13" Margin="0,0,10,6"/>
                                <TextBlock x:Name="LastWateredText" Grid.Row="1" Grid.Column="1" FontSize="13" Foreground="#333" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Next due:" Foreground="#888" FontSize="13" Margin="0,0,10,0"/>
                                <TextBlock x:Name="NextWateringText" Grid.Row="2" Grid.Column="1" FontSize="13" Foreground="#333"/>
                            </Grid>
                            <Button x:Name="WaterNowButton" Content="WATER NOW" Margin="0,12,0,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#2196F3" BorderBrush="#2196F3" Foreground="White"
                                    Click="WaterNow_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- Fertilization Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12"
                            materialDesign:ElevationAssist.Elevation="Dp2" Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="Sprout" Foreground="#8BC34A" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Fertilization" FontSize="18" FontWeight="Bold" Foreground="#8BC34A" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="FertilizationStatusBadge" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,14">
                                <TextBlock x:Name="FertilizationStatusText" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Frequency:" Foreground="#888" FontSize="13" Margin="0,0,10,6"/>
                                <TextBlock x:Name="FertilizationFreqText" Grid.Row="0" Grid.Column="1" FontSize="13" Foreground="#333" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Last fertilized:" Foreground="#888" FontSize="13" Margin="0,0,10,6"/>
                                <TextBlock x:Name="LastFertilizedText" Grid.Row="1" Grid.Column="1" FontSize="13" Foreground="#333" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Next due:" Foreground="#888" FontSize="13" Margin="0,0,10,0"/>
                                <TextBlock x:Name="NextFertilizationText" Grid.Row="2" Grid.Column="1" FontSize="13" Foreground="#333"/>
                            </Grid>
                            <Button x:Name="FertilizeNowButton" Content="FERTILIZE NOW" Margin="0,12,0,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#8BC34A" BorderBrush="#8BC34A" Foreground="White"
                                    Click="FertilizeNow_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Care Log Section -->
                <Border Background="White" CornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="History" Foreground="#2E7D32" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Recent Care History" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DataGrid x:Name="CareLogGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserResizeRows="False" HeadersVisibility="Column"
                                  Background="White" BorderThickness="0" Foreground="#333333"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                                  RowBackground="White" AlternatingRowBackground="#FAFAFA">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Type" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,6">
                                                <TextBlock Text="{Binding CareTypeIcon}" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CareType}" FontSize="13" VerticalAlignment="Center" Foreground="#444"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding FormattedDate}" Width="*"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="NoLogText" Text="No care events recorded yet." Foreground="#AAA"
                                   FontSize="14" HorizontalAlignment="Center" Margin="0,16,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
