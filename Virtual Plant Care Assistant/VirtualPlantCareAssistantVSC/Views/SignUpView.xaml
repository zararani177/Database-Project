<Page x:Class="VirtualPlantCareAssistantVSC.Views.SignUpView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="SignUpView">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/Images/login_bg.png" Stretch="UniformToFill"/>
        </Grid.Background>
        <Border Background="#F2FFFFFF" CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40" Width="400"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <StackPanel>
                <!-- Back Button -->
                <Button Style="{StaticResource MaterialDesignIconForegroundButton}" HorizontalAlignment="Left" Margin="-20,-20,0,0" Click="BackButton_Click">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="#666666"/>
                </Button>
                
                <materialDesign:PackIcon Kind="AccountPlus" Width="60" Height="60" Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Create Account" FontSize="28" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Join Virtual Plant Care Assistant" FontSize="14" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBox x:Name="NameTextBox" materialDesign:HintAssist.Hint="Full Name" Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,20" Foreground="#333333"/>
                <TextBox x:Name="EmailTextBox" materialDesign:HintAssist.Hint="Email Address" Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,20" Foreground="#333333"/>
                <PasswordBox x:Name="PasswordBox" materialDesign:HintAssist.Hint="Password" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             Margin="0,0,0,20" Foreground="#333333"/>
                <PasswordBox x:Name="ConfirmPasswordBox" materialDesign:HintAssist.Hint="Confirm Password" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             Margin="0,0,0,30" Foreground="#333333"/>

                <Button x:Name="SignUpButton" Content="SIGN UP" Style="{StaticResource MaterialDesignRaisedButton}" Height="45" Click="SignUpButton_Click" Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account? " Foreground="#666666" VerticalAlignment="Center"/>
                    <Button Content="Login" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2E7D32" Padding="0" Click="LoginButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
