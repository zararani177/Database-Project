<Page x:Class="VirtualPlantCareAssistantVSC.Views.CareHistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="CareHistoryView" Loaded="Page_Loaded">

    <Grid Background="#F4F7F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <materialDesign:PackIcon Kind="Leaf" Foreground="#2E7D32" Width="30" Height="30" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Plant Care" Foreground="#1B5E20" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="DashboardButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dashboard" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="CareScheduleButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Care Schedule" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="RemindersButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BellRingOutline" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Reminders" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2E7D32" HorizontalContentAlignment="Left" Height="50" Margin="10,5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="History" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Care History" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="History" Foreground="#2E7D32" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Care History" FontSize="28" FontWeight="Bold" Foreground="#1B5E20" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Filter Row -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Filter by:" FontSize="14" Foreground="#666" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox x:Name="FilterComboBox" Width="180" SelectionChanged="FilterComboBox_SelectionChanged"
                          FontSize="14">
                    <ComboBoxItem Content="All Events" IsSelected="True"/>
                    <ComboBoxItem Content="Watering Only"/>
                    <ComboBoxItem Content="Fertilization Only"/>
                </ComboBox>
            </StackPanel>

            <!-- DataGrid -->
            <Border Grid.Row="2" Background="White" CornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2" ClipToBounds="True">
                <Grid>
                    <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeRows="False" HeadersVisibility="Column"
                              Background="White" BorderThickness="0" Foreground="#333333"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Care Type" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,6">
                                            <Border CornerRadius="6" Padding="8,3"
                                                    Background="{Binding CareTypeColor}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding CareTypeIcon}" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding CareType}" FontSize="12" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Plant" Binding="{Binding PlantName}" Width="160"/>
                            <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding FormattedDate}" Width="*"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="NoHistoryText" Text="No care events recorded yet. Start watering or fertilizing your plants!"
                               Foreground="#AAA" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center" Margin="40"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
