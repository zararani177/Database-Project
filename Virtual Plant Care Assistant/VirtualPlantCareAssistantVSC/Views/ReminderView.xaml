<Page x:Class="VirtualPlantCareAssistantVSC.Views.ReminderView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="ReminderView" Loaded="Page_Loaded">

    <Grid Background="#F4F7F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <materialDesign:PackIcon Kind="Leaf" Foreground="#2E7D32" Width="30" Height="30" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Plant Care" Foreground="#1B5E20" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="DashboardButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dashboard" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="CareScheduleButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Care Schedule" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2E7D32" HorizontalContentAlignment="Left" Height="50" Margin="10,5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BellRingOutline" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Reminders" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#555" HorizontalContentAlignment="Left" Height="50" Margin="10,5" Click="CareHistoryButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="History" Width="22" Height="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Care History" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="BellRingOutline" Foreground="#2E7D32" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Reminders" FontSize="28" FontWeight="Bold" Foreground="#1B5E20"/>
                    <TextBlock Text="Plants overdue or due today for watering or fertilization" FontSize="13" Foreground="#777"/>
                </StackPanel>
            </StackPanel>

            <!-- Reminder Cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl x:Name="RemindersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" Margin="0,0,0,12"
                                        materialDesign:ElevationAssist.Elevation="Dp2">
                                    <Grid Margin="16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Urgency icon circle -->
                                        <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                                                Background="{Binding UrgencyColor}" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding CareIcon}" FontSize="24"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Plant + care info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PlantName}" FontSize="17" FontWeight="Bold" Foreground="#333"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border CornerRadius="6" Padding="8,2" Background="{Binding UrgencyColor}" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding UrgencyText}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="{Binding CareType}" FontSize="13" Foreground="#777" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Action button -->
                                        <Button Grid.Column="2" Content="{Binding ActionLabel}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="{Binding UrgencyColor}" BorderBrush="{Binding UrgencyColor}"
                                                Foreground="White" VerticalAlignment="Center"
                                                Tag="{Binding}" Click="ReminderAction_Click"
                                                Padding="16,6" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- All good state -->
                    <StackPanel x:Name="AllGoodPanel" Visibility="Collapsed"
                                HorizontalAlignment="Center" Margin="0,80,0,0">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#4CAF50"
                                                 Width="80" Height="80" HorizontalAlignment="Center"/>
                        <TextBlock Text="All plants are on track! 🌿" FontSize="22" FontWeight="Bold"
                                   Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                        <TextBlock Text="No watering or fertilization is overdue right now."
                                   FontSize="14" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
