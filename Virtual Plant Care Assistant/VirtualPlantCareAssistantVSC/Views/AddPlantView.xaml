<Page x:Class="VirtualPlantCareAssistantVSC.Views.AddPlantView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="AddPlantView">

    <Grid Background="#F4F7F6">
        <Border Background="White" CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40" Width="480"
                materialDesign:ElevationAssist.Elevation="Dp4">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" HorizontalAlignment="Left" Margin="-20,-20,0,0" Click="BackButton_Click">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="#4CAF50"/>
                    </Button>
                    <TextBlock Text="Add New Plant" FontSize="26" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                </Grid>

                <!-- Image Picker -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Height="150" Margin="0,0,0,20" Background="#FAFAFA" ClipToBounds="True">
                    <Grid>
                        <Image x:Name="PlantImagePreview" Stretch="UniformToFill"/>
                        <Button Content="Choose Image" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#4CAF50" BorderBrush="#4CAF50"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Click="ChooseImage_Click" x:Name="ChooseImageButton"/>
                    </Grid>
                </Border>

                <!-- Plant Name -->
                <TextBox x:Name="NameTextBox" materialDesign:HintAssist.Hint="Plant Name (e.g., Fernie)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15" Foreground="#333333"/>

                <!-- Species -->
                <TextBox x:Name="SpeciesTextBox" materialDesign:HintAssist.Hint="Species (e.g., Boston Fern)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15" Foreground="#333333"/>

                <!-- Watering & Fertilization frequency side by side -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="WaterDrop" Foreground="#2196F3" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Watering (days)" FontSize="11" Foreground="#777" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="FrequencyTextBox" materialDesign:HintAssist.Hint="Every X days"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#333333"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="Sprout" Foreground="#8BC34A" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Fertilization (days)" FontSize="11" Foreground="#777" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="FertilizationFrequencyTextBox" materialDesign:HintAssist.Hint="Every X days"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="#333333"/>
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <TextBox x:Name="NotesTextBox" materialDesign:HintAssist.Hint="Notes (optional)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,25" Foreground="#333333"/>

                <!-- Save Button -->
                <Button x:Name="SaveButton" Content="SAVE PLANT" Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="45" Click="SaveButton_Click" Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
